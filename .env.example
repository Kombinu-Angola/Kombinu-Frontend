# ============================================================
# KOMBINU Frontend — Variaveis de Ambiente
# Copiar este ficheiro para .env.local e preencher os valores
# NUNCA commitar .env.local no repositorio
# ============================================================

# URL base da API do backend Django (sem barra no final)
# Desenvolvimento local:  http://localhost:8000/api
# Staging (Vercel):       https://api-staging.kombinu.ao/api
# Producao:               https://api.kombinu.ao/api
VITE_API_URL=http://localhost:8000/api

# Ambiente da aplicacao (development | staging | production)
VITE_ENV=development
